# Vertex AI + Pinecone RAG
PINECONE_API_KEY="pcsk-..."
PINECONE_INDEX_VERTEX_1408="your-vertex-1408-index"
PINECONE_NAMESPACE="default"

# GCP Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="multimodalembedding@001"
GOOGLE_VERTEX_EMBEDDING_DIMENSION="1408"

# Auth: either short-lived token or service account
GOOGLE_VERTEX_ACCESS_TOKEN=""
GOOGLE_APPLICATION_CREDENTIALS="your-system-path"

# Optional: GCS bucket for video uploads
VERTEX_VIDEO_GCS_BUCKET=""

# Optional: Gemini model for immersive audio interpretation
# Optional: Gemini model for immersive audio interpretation
GOOGLE_VERTEX_GEMINI_MODEL="gemini-2.5-flash"
