# AWS Bedrock Nova + Pinecone RAG
PINECONE_API_KEY="pcsk-..."
PINECONE_INDEX_AWS_NOVA_1024="your-aws-nova-1024-index"
PINECONE_NAMESPACE="default"

# AWS Configuration (uses default credential chain or explicit keys)
AWS_REGION="us-east-1"
AWS_NOVA_EMBEDDING_MODEL="amazon.nova-2-multimodal-embeddings-v1:0"
AWS_NOVA_EMBEDDING_DIMENSION="1024"
AWS_NOVA_VIDEO_MAX_BYTES="20971520"

# Optional: OpenAI for audio transcription fallback
OPENAI_API_KEY=""
