# OpenAI + Pinecone RAG
OPENAI_API_KEY="sk-..."
PINECONE_API_KEY="pcsk-..."

# Pinecone indexes (must have matching dimensions)
PINECONE_INDEX_OPENAI_TEXT_3072="your-openai-text-3072-index"
PINECONE_INDEX_OPENAI_CLIP_512="your-openai-clip-512-index"
PINECONE_NAMESPACE="default"

# OpenAI embedding model
OPENAI_TEXT_EMBEDDING_MODEL="text-embedding-3-large"
OPENAI_TEXT_EMBEDDING_DIMENSION="3072" # Support also 1024, 256 dimentions - Best is 3072

# CLIP model for image/video embeddings
# Options: clip-ViT-B-32 (512d), clip-ViT-L-14 (768d), clip-ViT-H-14 (1024d)
CLIP_MODEL_NAME="clip-ViT-B-32"
OPENAI_CLIP_EMBEDDING_DIMENSION="512"

# Chunking
CHUNK_STRATEGY="paragraph"
CHUNK_MAX_CHARS="1200"
