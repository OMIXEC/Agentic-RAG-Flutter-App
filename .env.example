# RAG Demo v2 configuration

# Pinecone
PINECONE_API_KEY="pcsk-..."
PINECONE_INDEX="your-index-name"
PINECONE_BASE_URL="https://your-index-host.pinecone.io"

# Data loading
DATA_FOLDER="txts"

# Google Gemini (response generation)
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# Google Vertex AI multimodal embeddings
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="multimodalembedding@001"
GOOGLE_VERTEX_EMBEDDING_DIMENSION="1408"

# Option A (recommended for backend): service account JSON path
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# Option B (demo only): short-lived bearer token (used by Flutter + Python fallback)
# Generate with:
# gcloud auth print-access-token
GOOGLE_VERTEX_ACCESS_TOKEN=""

# Legacy aliases still accepted by backend for compatibility:
# PINECONE_KEY, OPENAI_KEY
