# RAG Demo v2.1 (with v1 backward compatibility)

# Pinecone
PINECONE_API_KEY="pcsk-..."
PINECONE_KEY="" # v1 alias (optional)
PINECONE_INDEX="your-index-name"
PINECONE_BASE_URL="https://your-index-host.pinecone.io"

# Data loading
DATA_FOLDER="txts"

# Provider routing
# EMBEDDING_PROVIDER: auto | vertex | openai
# LLM_PROVIDER: gemini | openai
EMBEDDING_PROVIDER="auto"
LLM_PROVIDER="gemini"

# Google Gemini (responses)
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# Google Vertex AI embeddings (multimodal embedding)
GOOGLE_CLOUD_PROJECT="Aion"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="multimodalembedding@001"
GOOGLE_VERTEX_EMBEDDING_DIMENSION="1408"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
GOOGLE_VERTEX_ACCESS_TOKEN="" # optional short-lived token

# OpenAI support (v2 + v1 compatibility)
OPENAI_API_KEY="sk-..."
OPENAI_KEY="" # v1 alias (optional)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_CHAT_MODEL="gpt-4.1-mini"
