# AWS Nova-only separated pipeline
MULTIMODAL_PROVIDER="aws_nova"

PINECONE_API_KEY="pcsk-..."
PINECONE_NAMESPACE="aws"
PINECONE_INDEX_AWS_NOVA_1024="your-aws-nova-1024-index"
PINECONE_INDEX_HOST_AWS_NOVA_1024=""

AWS_REGION="us-east-1"
AWS_NOVA_EMBEDDING_MODEL="amazon.nova-2-multimodal-embeddings-v1:0"
AWS_NOVA_EMBEDDING_DIMENSION="1024"
AWS_NOVA_EXPECTED_DIMENSION="1024"

OPENAI_API_KEY=""
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"

TEXT_DATA_FOLDER_AWS="data/aws/txt"
IMAGE_DATA_FOLDER_AWS="data/aws/image"
VIDEO_DATA_FOLDER_AWS="data/aws/video"
AUDIO_DATA_FOLDER_AWS="data/aws/audio"
