# Core
PINECONE_API_KEY="pcsk-..."
JWT_SECRET="dev-secret-change-me"
JWT_ALGORITHM="HS256"
JWT_AUDIENCE="search-memory"
JWT_ISSUER="search-memory-backend"
MEMORY_DB_PATH="search_memory.db"

# Indexing
# For vertex/aws providers, use PINECONE_INDEX
PINECONE_INDEX="your-main-index"
PINECONE_INDEX_HOST=""            # only if Flutter queries Pinecone directly
PINECONE_INDEX_HOST_VERTEX_1408=""
PINECONE_INDEX_HOST_OPENAI_TEXT_3072=""
PINECONE_INDEX_HOST_OPENAI_CLIP_512=""
PINECONE_INDEX_HOST_AWS_NOVA_1024=""
PINECONE_INDEX_HOST_LEGACY_TEXT=""
PINECONE_INDEX_HOST_LEGACY_MEDIA=""
PINECONE_INDEX_VERTEX_1408="your-vertex-1408-index"
PINECONE_INDEX_OPENAI_TEXT_3072="your-openai-text-3072-index"
PINECONE_INDEX_OPENAI_CLIP_512="your-openai-clip-512-index"
PINECONE_INDEX_AWS_NOVA_1024="your-aws-nova-1024-index"
PINECONE_INDEX_LEGACY_TEXT="your-legacy-text-index"
PINECONE_INDEX_LEGACY_MEDIA="your-legacy-media-index"
PINECONE_NAMESPACE="default-user-or-batch"

# For openai_clip provider, use split indexes due to dim mismatch
PINECONE_TEXT_INDEX="your-text-index"
PINECONE_MEDIA_INDEX="your-media-index" # optional; if omitted falls back to compatibility mode

# Data folders
DATA_FOLDER="data/txt"
TEXT_DATA_FOLDER="data/txt"
IMAGE_DATA_FOLDER="data/image"
VIDEO_DATA_FOLDER="data/video"
AUDIO_DATA_FOLDER="data/audio"

# Optional provider-scoped folder separation
TEXT_DATA_FOLDER_OPENAI="data/openai/txt"
IMAGE_DATA_FOLDER_OPENAI="data/openai/image"
VIDEO_DATA_FOLDER_OPENAI="data/openai/video"
AUDIO_DATA_FOLDER_OPENAI="data/openai/audio"

TEXT_DATA_FOLDER_VERTEX="data/vertex/txt"
IMAGE_DATA_FOLDER_VERTEX="data/vertex/image"
VIDEO_DATA_FOLDER_VERTEX="data/vertex/video"
AUDIO_DATA_FOLDER_VERTEX="data/vertex/audio"

TEXT_DATA_FOLDER_AWS="data/aws/txt"
IMAGE_DATA_FOLDER_AWS="data/aws/image"
VIDEO_DATA_FOLDER_AWS="data/aws/video"
AUDIO_DATA_FOLDER_AWS="data/aws/audio"

TEXT_DATA_FOLDER_LEGACY="data/legacy/txt"
IMAGE_DATA_FOLDER_LEGACY="data/legacy/image"
VIDEO_DATA_FOLDER_LEGACY="data/legacy/video"
AUDIO_DATA_FOLDER_LEGACY="data/legacy/audio"

# Provider selector: openai_clip | vertex | aws_nova
MULTIMODAL_PROVIDER="openai_clip" # openai_clip | vertex | aws_nova | legacy_multimodal

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_TEXT_EMBEDDING_MODEL="text-embedding-3-large"
OPENAI_CHAT_MODEL="gpt-4.1-mini"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
CLIP_MODEL_NAME="clip-ViT-B-32"
OPENAI_TEXT_EMBEDDING_DIMENSION="3072"
OPENAI_CLIP_EMBEDDING_DIMENSION="512"
OPENAI_CLIP_STRICT="true" # true => require separate media index

# Vertex AI (GCP)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_VERTEX_MODEL="multimodalembedding@001"
GOOGLE_VERTEX_EMBEDDING_DIMENSION="1408"
GOOGLE_VERTEX_EXPECTED_DIMENSION="1408"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
GOOGLE_VERTEX_ACCESS_TOKEN=""
VERTEX_VIDEO_GCS_BUCKET="" # optional bucket for native video embeddings
GCS_BUCKET=""              # backend signed upload bucket

# AWS Bedrock Nova embeddings
AWS_REGION="us-east-1"
AWS_NOVA_EMBEDDING_MODEL="amazon.nova-2-multimodal-embeddings-v1:0"
AWS_NOVA_EMBEDDING_DIMENSION="1024"
AWS_NOVA_EXPECTED_DIMENSION="1024"

# Video sampling fallback
VIDEO_FRAME_SAMPLE_COUNT="4"

# Flutter app backend-first mode
BACKEND_API_BASE_URL="http://localhost:8000"
BACKEND_AUTH_TOKEN=""
